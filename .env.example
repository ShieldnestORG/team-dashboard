# Server
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=true

# Auth (required for authenticated deployment modes)
# BETTER_AUTH_SECRET=<run: openssl rand -base64 32>
# PAPERCLIP_PUBLIC_URL=https://your-vercel-domain.vercel.app
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-vercel-domain.vercel.app
# PAPERCLIP_ALLOWED_HOSTNAMES=your-vps-ip

# AI Provider Keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Firecrawl (plugin config is set via API, only embedding key is env-based)
# FIRECRAWL_EMBEDDING_API_KEY=

# Site Metrics (shared secret for external site analytics ingestion)
# SITE_METRICS_KEY=<run: openssl rand -base64 32 | tr -d '/+=' | head -c 40>

# Intel Engine (blockchain intelligence ingestion + vector search)
# EMBED_URL=http://100.67.128.51:8080  # VPS1 shield-llm BGE-M3 over Tailnet (147.79.78.251:8000 = dead VPS3, do not use)
# EMBED_API_KEY=
# INTEL_INGEST_KEY=<run: openssl rand -base64 32 | tr -d '/+=' | head -c 40>
# GITHUB_TOKEN=<optional: increases GitHub API rate limit from 60 to 5000 req/hr>

# ── Moltbook (AI agent social network) ──
# MOLTBOOK_API_KEY=<registered via plugin-moltbook moltbook-register tool>

# ── YouTube Pipeline ──
# Set to "false" to leave the 5 YouTube crons dormant (useful on hosts
# without Playwright/ffmpeg/Grok TTS). Defaults to enabled.
# YT_PIPELINE_ENABLED=false

# ── Video Edit Pipeline (browser-use/video-use) ──
# Absolute path to the video-use entry script on the host. Mount it into the
# container if video-use is installed on the host rather than baked into the
# image. Leaving unset shows an "Engine not configured" banner in the UI and
# jobs queue but won't run.
# VIDEO_USE_BIN=/opt/video-use/bin/video-use
# Base dir for raw-input folders + outputs. Defaults to /paperclip/video-edit.
# VIDEO_EDIT_DATA_DIR=/paperclip/video-edit
# ElevenLabs Scribe API key — required by video-use for word-level transcription.
# Sign up: https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=

# ── Alerting (SMTP) ──
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=

# ── Bluesky (socials relayer) ──
# Drives the AT-Proto adapter at services/platform-publishers/bluesky.ts.
# Get an app password (NOT your account password) at:
#   https://bsky.app/settings/app-passwords
# Use the full handle including .bsky.social (or your custom domain).
# BLUESKY_HANDLE=
# BLUESKY_APP_PASSWORD=
# Optional — defaults to https://bsky.social. Override only for self-hosted PDS.
# BLUESKY_SERVICE=https://bsky.social

# ── Optimize Me SSO bridge ──
# Cross-org trust anchor for the Optimize Me ("architect") SSO bridge. Used to
# HMAC-sign the short-lived launch assertion minted by
# POST /api/portal/optimize-me/launch. MUST be IDENTICAL to the
# BRIDGE_SHARED_SECRET set in the Optimize Me (Vercel) env. Dedicated secret —
# do NOT reuse PORTAL_SESSION_SECRET across the org boundary.
# Generate once: openssl rand -hex 32   (min 32 chars)
# BRIDGE_SHARED_SECRET=
# Optimize Me app surface the launchUrl points at. Defaults to
# https://app.optimize-me.coherencedaddy.com — override for staging/local.
# OPTIMIZE_ME_APP_URL=https://app.optimize-me.coherencedaddy.com

# ── Shop sharer referral program ──
# Storefront root the /?ref=<code> link points at (what users share with others).
# Default: https://shop.coherencedaddy.com
# SHOP_SHARE_BASE_URL=https://shop.coherencedaddy.com
# Personal "your code is live" landing the welcome email CTA opens.
# Default: https://shop.coherencedaddy.com/share (middleware rewrites to /shop/share)
# SHOP_SHARE_LANDING_URL=https://shop.coherencedaddy.com/share
