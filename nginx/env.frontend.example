# ── Frontend Environment Variables ─────────────────────────────────────────
# Copy to /opt/team-dashboard/.env.frontend and fill in values.
# These are read by the Next.js frontend container.

# Backend API URL (Docker internal network — use service name, not IP)
TEAM_DASHBOARD_URL=http://server:3100
REELS_API_URL=http://server:3100

# Database (Neon — same as backend)
DATABASE_URL=${DATABASE_URL}
POSTGRES_URL=${DATABASE_URL}

# Stripe (donations)
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}

# Email (Resend)
RESEND_API_KEY=${RESEND_API_KEY}

# Blog API
BLOG_API_KEY=${BLOG_API_KEY}

# Embeddings
EMBED_URL=http://147.79.78.251:8000
EMBED_API_KEY=${EMBED_API_KEY}

# Site metrics
SITE_METRICS_KEY=${SITE_METRICS_KEY}
TEAM_DASHBOARD_COMPANY_ID=8365d8c2-ea73-4c04-af78-a7db3ee7ecd4

# Public site URL
NEXT_PUBLIC_SITE_URL=https://coherencedaddy.com

# Cron secret (for IndexNow, metrics — these run as cron jobs via Next.js)
CRON_SECRET=${CRON_SECRET}
